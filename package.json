{
  "name": "ranch_ledger",
  "version": "2.0.0",
  "description": "On-chain cattle lifecycle ledger built on Solidity 0.8.28, Foundry + OpenZeppelin v5.1. Off-chain Express + ethers v6 service bridges the on-chain BovineTracking contract with MongoDB.",
  "main": "server.js",
  "scripts": {
    "build": "forge build",
    "test": "forge test -vv",
    "test:gas": "forge test --gas-report",
    "anvil": "anvil --accounts 100 --balance 1000 --block-time 1",
    "deploy": "forge script script/Deploy.s.sol --rpc-url http://127.0.0.1:8545 --broadcast",
    "bulk-mint": "forge script script/BulkMint.s.sol --rpc-url http://127.0.0.1:8545 --broadcast",
    "dev": "concurrently -k -n anvil,server -c green,blue \"npm:anvil\" \"node server.js\"",
    "simulate:100": "bash scripts/simulate_100.sh",
    "deploy:amoy": "forge script script/Deploy.s.sol --rpc-url $AMOY_RPC_URL --broadcast --private-key $PRIVATE_KEY_AMOY -vvvv",
    "fmt": "forge fmt",
    "fmt:check": "forge fmt --check",
    "clean": "forge clean && rm -rf out cache broadcast deployments"
  },
  "keywords": [
    "rastreabilidade",
    "certificacao",
    "origem",
    "blockchain",
    "gado",
    "transparencia",
    "privacidade",
    "proveniencia",
    "seguranca",
    "smart contracts",
    "foundry",
    "openzeppelin",
    "ethers",
    "supply-chain"
  ],
  "author": "Enrique Souza",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.5",
    "ethers": "^6.13.4",
    "express": "^4.19.2",
    "mongoose": "^8.5.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
